# ============================================================================
# Variables de entorno para Gastos Familiares V2
# ============================================================================
# 1. Copiá este archivo a `.env.local` (NO commitear .env.local)
# 2. Completá los valores desde Firebase Console > Configuración del proyecto > General
# 3. Solo variables con prefijo VITE_ son expuestas al cliente
# ----------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: App Check (recomendado para producción)
# VITE_FIREBASE_MEASUREMENT_ID=
