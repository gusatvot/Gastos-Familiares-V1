```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Compiled files
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.class
*.jar
*.war
*.ear

# Archives
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.rar
*.7z
*.gz
*.bz2
*.xz
*.Z
*.lz
*.lzo
*.lz4
*.zst
*.cab
*.arj
*.rpm
*.deb
```